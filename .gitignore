# Rust build output (shared workspace target dir)
/target
**/target/

# rustfmt backups
**/*.rs.bk

# npm (daml-fmt differential harness uses node, no deps installed)
node_modules/
/docs/node_modules/
/docs/.vitepress/dist/
/docs/.vitepress/cache/

